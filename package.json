{
  "name": "chronomel",
  "version": "0.0.0",
  "description": "Temporal viewer of orthophotographs from Métropole Européenne de Lille (1930-2025)",
  "type": "module",
  "private": true,
  "keywords": [
    "geospatial",
    "temporal",
    "orthophoto",
    "leaflet",
    "leaflet-atlas",
    "timeline",
    "vite",
    "typescript",
    "lille",
    "france"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "validate-config": "node scripts/validate-config.mjs",
    "validate-all": "npm run validate-config && npm run build",
    "refresh-data": "node scripts/refresh-data.mjs",
    "refresh-bati": "node scripts/refresh-bati-remarquable.mjs",
    "refresh-transport": "node scripts/refresh-transport.mjs",
    "refresh-hydro": "node scripts/refresh-hydro.mjs",
    "refresh-vegetation": "node scripts/refresh-vegetation.mjs",
    "refresh-equipements": "node scripts/refresh-equipements.mjs"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "leaflet-atlas": "^0.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "vite": "^8.1.2"
  }
}
